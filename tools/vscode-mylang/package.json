{
  "name": "mylang-syntax",
  "displayName": "MyLang Syntax",
  "description": "Syntax highlighting and a lightweight LSP for the MyLang sources in this repo.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mylang"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mylang",
        "aliases": [
          "MyLang"
        ],
        "extensions": [
          ".mln"
        ]
      },
      {
        "id": "mymasm",
        "aliases": [
          "MyMasm"
        ],
        "extensions": [
          ".masm"
        ]
      }
    ],
    "grammars": [
      {
        "language": "mymasm",
        "scopeName": "source.mymasm",
        "path": "./syntaxes/mymasm.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MyLang",
      "properties": {
        "mylang.lsp.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable used to start the MyLang LSP server."
        },
        "mylang.lsp.semanticTokens": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic tokens from the MyLang LSP."
        }
      }
    }
  }
}
