{
  "scopeName": "source.mylang",
  "name": "MyLang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#type-definitions" },
    { "include": "#function-definitions" },
    { "include": "#package-import" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#type-usage" },
    { "include": "#constants" },
    { "include": "#function-calls" },
    { "include": "#member-access" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mylang",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mylang",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mylang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mylang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.mylang",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mylang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "type-definitions": {
      "patterns": [
        {
          "name": "meta.typedef.alias.mylang",
          "match": "\\btypedef\\b[^;{}]*\\b([A-Za-z_][A-Za-z0-9_]*)\\s*;",
          "captures": {
            "1": { "name": "entity.name.type.typedef.mylang" }
          }
        },
        {
          "name": "meta.typedef.struct.alias.mylang",
          "match": "}\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*;",
          "captures": {
            "1": { "name": "entity.name.type.typedef.mylang" }
          }
        },
        {
          "name": "meta.struct.name.mylang",
          "match": "\\bstruct\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.struct.mylang" }
          }
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "name": "meta.function.definition.mylang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(\\*+\\s*)?([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "storage.type.return-type.mylang" },
            "2": { "name": "keyword.operator.pointer.mylang" },
            "3": { "name": "entity.name.function.mylang" }
          }
        }
      ]
    },
    "package-import": {
      "patterns": [
        {
          "name": "meta.package.mylang",
          "match": "\\b(package)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.package.mylang" },
            "2": { "name": "entity.name.namespace.mylang" }
          }
        },
        {
          "name": "meta.import.mylang",
          "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*;)",
          "captures": {
            "1": { "name": "keyword.other.import.mylang" },
            "2": { "name": "entity.name.namespace.mylang" }
          }
        },
        {
          "name": "meta.import.from.mylang",
          "match": "\\b(from)\\s+(\"[^\"]*\"|[A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.import.mylang" },
            "2": { "name": "entity.name.namespace.mylang" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mylang",
          "match": "\\b(if|else|while|do|for|switch|case|default|break|continue|return|yield|of)\\b"
        },
        {
          "name": "keyword.other.import.mylang",
          "match": "\\b(import|from|export|package)\\b"
        },
        {
          "name": "keyword.control.case-arrow.mylang",
          "match": "->"
        },
        {
          "name": "variable.language.wildcard.mylang",
          "match": "\\b_\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mylang",
          "match": "\\b(bool|i8|i16|i32|u8|u16|u32|char|float|double|void|long|short)\\b"
        },
        {
          "name": "storage.modifier.mylang",
          "match": "\\b(const|static|extern|auto|register|typedef|struct|union|enum)\\b"
        },
        {
          "name": "support.type.user.mylang",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "type-usage": {
      "patterns": [
        {
          "name": "meta.type.reference.mylang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\*+\\s*)?[A-Za-z_][A-Za-z0-9_]*\\s*(?:\\[[^\\]]*\\]\\s*)?(?:[=;,)]))",
          "captures": {
            "1": { "name": "support.type.reference.mylang" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.mylang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.mylang",
          "match": "\\b(null)\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function-call.mylang",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.mylang" }
          }
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "meta.member.access.mylang",
          "match": "\\.\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "0": { "name": "punctuation.accessor.dot.mylang" },
            "1": { "name": "variable.other.member.mylang" }
          }
        },
        {
          "name": "meta.member.access.arrow.mylang",
          "match": "->\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "0": { "name": "punctuation.accessor.arrow.mylang" },
            "1": { "name": "variable.other.member.mylang" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.mylang",
          "match": "=(?!=)"
        },
        {
          "name": "keyword.operator.comparison.mylang",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.mylang",
          "match": "\\+\\+|--|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.logical.mylang",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.mylang",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "keyword.operator.ternary.mylang",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.address.mylang",
          "match": "&"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mylang",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.decimal.mylang",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.mylang",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.group.begin.mylang",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.mylang",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.separator.delimiter.mylang",
          "match": ",|;"
        }
      ]
    }
  }
}
