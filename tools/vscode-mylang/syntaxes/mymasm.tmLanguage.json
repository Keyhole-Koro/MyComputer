{
  "scopeName": "source.mymasm",
  "name": "MyMasm",
  "patterns": [
    { "include": "#comments" },
    { "include": "#moduleImports" },
    { "include": "#labels" },
    { "include": "#instructions" },
    { "include": "#registers" },
    { "include": "#numbers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.mymasm",
          "match": ";.*$"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.mymasm",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "entity.name.label.mymasm" }
          }
        }
      ]
    },
    "moduleImports": {
      "patterns": [
        {
          "name": "meta.import.from.mymasm",
          "match": "^\\s*(import)\\s+(\\{\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*\\s*\\}|[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)\\s+(from)\\s+(\"[^\"]+\")",
          "captures": {
            "1": { "name": "keyword.control.import.mymasm" },
            "2": { "name": "entity.name.import.mymasm" },
            "3": { "name": "keyword.control.from.mymasm" },
            "4": { "name": "string.quoted.double.path.mymasm" }
          }
        },
        {
          "name": "meta.import.mymasm",
          "match": "^\\s*(import)\\s+(\\{\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*\\s*\\}|[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.control.import.mymasm" },
            "2": { "name": "entity.name.import.mymasm" }
          }
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "name": "keyword.other.mnemonic.mymasm",
          "match": "\\b(mov|movi|movis|load|store|push|pop|add|addis|sub|and|or|xor|shl|shr|cmp|jmp|jz|jnz|jg|jl|jge|jle|jne|out|halt)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.language.register.mymasm",
          "match": "\\b(r[0-7]|bp|sp|pc|lr)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mymasm",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.decimal.mymasm",
          "match": "-?\\b[0-9]+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.mymasm",
          "match": ","
        }
      ]
    }
  }
}
